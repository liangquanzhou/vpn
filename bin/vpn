#!/bin/bash
# vpn - OpenConnect VPN connection manager
# Automatic DNS healing, route cleanup, and reconnection support

# --- Configuration ---
CONFIG_FILE="${VPN_CONFIG:-$HOME/.config/vpn/config.sh}"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "VPN config not found: $CONFIG_FILE"
    echo "Create it from the example: cp config.example.sh ~/.config/vpn/config.sh"
    exit 1
fi

source "$CONFIG_FILE"

# Validate required settings
for var in VPN_HOST VPN_USER VPN_GROUP; do
    if [[ -z "${!var:-}" ]]; then
        echo "Required config missing: $var in $CONFIG_FILE"
        exit 1
    fi
done

# Build endpoint list for route cleanup
VPN_DOMAINS=("$VPN_HOST")
if [[ -n "${VPN_ENDPOINT_PREFIX:-}" && -n "${VPN_ENDPOINT_SUFFIX:-}" ]]; then
    for i in $(seq ${VPN_ENDPOINT_RANGE_START:-1} ${VPN_ENDPOINT_RANGE_END:-10}); do
        VPN_DOMAINS+=("${VPN_ENDPOINT_PREFIX}${i}${VPN_ENDPOINT_SUFFIX}")
    done
fi

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# 带超时的 DNS 解析（替代 dscacheutil，避免无限阻塞）
resolve_host() {
    dig +short +time=2 +tries=1 "$1" 2>/dev/null | grep -E '^[0-9.]+'
}

# 获取当前活跃的网络服务名（Wi-Fi / USB LAN 等）
get_active_service() {
    while IFS= read -r svc; do
        [[ "$svc" == \** ]] && continue
        local ip
        ip=$(networksetup -getinfo "$svc" 2>/dev/null | awk -F': ' '/^IP address:/{print $2}')
        if [[ -n "$ip" && "$ip" != "none" ]]; then
            echo "$svc"
            return 0
        fi
    done < <(networksetup -listallnetworkservices)
    return 1
}

# 确保 DNS 能解析 VPN 域名（自动修复）
ensure_dns() {
    # 已经能解析，直接返回
    if resolve_host "$VPN_HOST" | head -1 | grep -qE '^[0-9.]+'; then
        return 0
    fi

    log_warn "DNS 无法解析 $VPN_HOST，自动修复中..."

    local service
    service=$(get_active_service)
    if [ -z "$service" ]; then
        log_error "未找到活跃的网络接口"
        return 1
    fi

    # 第一步：恢复 DHCP 自动 DNS
    log_info "恢复 DHCP DNS（接口: $service）..."
    sudo networksetup -setdnsservers "$service" empty
    sudo dscacheutil -flushcache 2>/dev/null
    sudo killall -HUP mDNSResponder 2>/dev/null
    sleep 1

    if resolve_host "$VPN_HOST" | head -1 | grep -qE '^[0-9.]+'; then
        log_info "DNS 已修复（DHCP 自动获取）"
        return 0
    fi

    # 第二步：DHCP DNS 也不行，用公共 DNS 兜底
    log_warn "DHCP DNS 也无法解析，切换到公共 DNS..."
    sudo networksetup -setdnsservers "$service" 8.8.8.8 114.114.114.114
    sudo dscacheutil -flushcache 2>/dev/null
    sudo killall -HUP mDNSResponder 2>/dev/null
    sleep 1

    if resolve_host "$VPN_HOST" | head -1 | grep -qE '^[0-9.]+'; then
        log_info "DNS 已修复（公共 DNS）"
        return 0
    fi

    log_error "DNS 仍无法解析 $VPN_HOST，请检查网络连接"
    return 1
}

# 清理残留路由（VPN IP 走旧网关的情况）
cleanup_routes() {
    local default_gw
    default_gw=$(route -n get default 2>/dev/null | awk '/gateway:/{print $2}')
    [ -z "$default_gw" ] && return

    # 收集所有 VPN 相关 IP（使用 dig 带超时，不会卡死）
    local ips
    ips=$(
        {
            for host in "${VPN_DOMAINS[@]}"; do
                resolve_host "$host"
            done
            if [[ -n "${VPN_ROUTE_PATTERN:-}" ]]; then
                netstat -rn | awk "/${VPN_ROUTE_PATTERN}/{print \$1}"
            fi
        } | grep -E '^[0-9.]+$' | sort -u
    )

    [ -z "$ips" ] && return

    # 3) 逐个检查并清理残留
    local route_gw cleaned=0
    while read -r ip; do
        [ -z "$ip" ] && continue
        route_gw=$(route -n get "$ip" 2>/dev/null | awk '/gateway:/{print $2}')
        if [ -n "$route_gw" ] && [ "$route_gw" != "$default_gw" ]; then
            sudo route -n delete "$ip" >/dev/null 2>&1
            log_info "已清理残留路由: $ip -> $route_gw (当前默认网关 $default_gw)"
            ((cleaned++))
        fi
    done <<< "$ips"

    [ $cleaned -eq 0 ] || log_info "共清理 $cleaned 条残留路由"
}

# 检查 VPN 状态
vpn_status() {
    if pgrep -x openconnect > /dev/null; then
        log_info "VPN 正在运行"
        ifconfig | grep -A 5 "utun" | grep "inet " | head -1 | awk '{print "VPN IP: "$2}'
        return 0
    else
        log_warn "VPN 未运行"
        return 1
    fi
}

# 断开 VPN
vpn_disconnect() {
    if pgrep -x openconnect > /dev/null; then
        log_info "断开 VPN..."
        sudo killall openconnect 2>/dev/null
        sleep 1
        log_info "VPN 已断开"
    else
        log_warn "VPN 未在运行"
    fi
    cleanup_routes
}

# 连接 VPN（分步认证：sudo → 邮箱密码 → D盾验证码）
vpn_connect() {
    if pgrep -x openconnect > /dev/null; then
        log_warn "VPN 已经在运行"
        vpn_status
        return 0
    fi

    if ! command -v openconnect >/dev/null 2>&1; then
        log_error "未找到 openconnect，请先安装：brew install openconnect"
        return 1
    fi

    if ! command -v expect >/dev/null 2>&1; then
        log_error "未找到 expect，请先安装：brew install expect"
        return 1
    fi

    # DNS 检查 + 路由清理
    ensure_dns || return 1
    cleanup_routes

    log_info "VPN 连接 (用户: $VPN_USER)"

    # ── Step 1/3: 电脑密码 ──
    log_info "── Step 1/3: 电脑密码 ──"
    sudo -v || { log_error "sudo 认证失败"; return 1; }
    log_info "Step 1 通过"

    # ── Step 2/3: 邮箱密码（expect 提交后等 challenge 表单确认成功）──
    local pass
    log_info "── Step 2/3: 邮箱密码 ──"
    echo -n "邮箱密码: "
    read -s pass; echo

    # Step 3 将在 Step 2 成功后由 expect 提示（确保 D盾推送已发出）

    # 预解析实际 dvpn 服务器（ezvpn 负载均衡器不支持 XML POST，会导致 openconnect 降级）
    log_info "解析 VPN 服务器..."
    local actual_host
    actual_host=$(/usr/bin/curl -sSk --noproxy '*' \
        -H "X-Transcend-Version: 1" \
        -H "User-Agent: AnyConnect Darwin_arm64 4.10.08025" \
        -D - -o /dev/null "https://$VPN_HOST/" 2>/dev/null \
        | grep -i '^Location:' | tr -d '\r' | awk '{print $2}' | sed 's|^https://||;s|/$||')

    if [[ -z "$actual_host" ]]; then
        log_warn "无法解析 dvpn 服务器，使用原始地址"
        actual_host="$VPN_HOST"
    else
        log_info "实际服务器: $actual_host"
    fi

    sudo env \
        "_VP=$pass" \
        "_VH=$actual_host" \
        "_VU=$VPN_USER" \
        "_VG=$VPN_GROUP" \
        "_VD=${VPN_DPD_TIMEOUT:-30}" \
        "_VND=${VPN_NO_DTLS:-false}" \
    /usr/bin/expect -c '
set timeout 60

set oc_args [list /opt/homebrew/bin/openconnect \
    --useragent=AnyConnect\ Darwin_arm64\ 5.1.11388 \
    --form-entry=main:username=$env(_VU) \
    --form-entry=main:password=$env(_VP) \
    --authgroup=$env(_VG) \
    --force-dpd=$env(_VD) \
    --background]

if {$env(_VND) eq "true"} {
    lappend oc_args --no-dtls
}
lappend oc_args "https://$env(_VH)/"

log_user 0
spawn {*}$oc_args
log_user 1
log_file -noappend /tmp/vpn_debug.log

set fail_count 0
expect {
    -re "Response:|challenge_code:" {
        # Step 2 成功（邮箱密码通过，XML 模式 prompt 是 "Response:"）
        puts "\r\n\033\[0;32m\[INFO\]\033\[0m Step 2 通过"
        puts "\033\[0;32m\[INFO\]\033\[0m ── Step 3/3: D盾验证码 ──"
        puts "\033\[0;32m\[INFO\]\033\[0m 请现在打开 D-Chat → 工作台 → D盾，查看6位验证码"
        puts -nonewline "验证码: "
        flush stdout
        interact -nobuffer -re "\r" return
        # 等待隧道建立（eof = fork 到后台）或认证失败
        expect {
            eof {
                puts "\r\n\033\[0;32m\[INFO\]\033\[0m Step 3 通过"
                exit 0
            }
            -ex "Login failed" {
                puts "\r\n\033\[0;31m\[ERROR\]\033\[0m D盾验证码错误或已过期"
                exit 1
            }
            timeout {
                puts "\r\n\033\[0;31m\[ERROR\]\033\[0m 隧道建立超时"
                exit 1
            }
        }
    }
    -ex "Login failed" {
        incr fail_count
        if {$fail_count >= 3} {
            puts "\r\n\033\[0;31m\[ERROR\]\033\[0m 邮箱密码错误（连续失败 $fail_count 次）"
            exit 2
        }
        exp_continue
    }
    timeout {
        puts "\r\n\033\[0;31m\[ERROR\]\033\[0m 连接超时"
        exit 1
    }
}
'

    local ec=$?
    unset pass

    case $ec in
        0)
            sleep 2
            if pgrep -x openconnect > /dev/null; then
                log_info "VPN 已连接（后台运行）"
                vpn_status
            else
                log_warn "openconnect 进程未检测到"
                return 1
            fi
            ;;
        2)
            log_error "请确认密码是否正确、账号是否被锁定"
            return 1
            ;;
        *)
            log_error "连接失败（详见 /tmp/vpn_debug.log）"
            return 1
            ;;
    esac
}

# 主逻辑
case "${1:-connect}" in
    connect|c)
        vpn_connect
        ;;
    disconnect|d|stop)
        vpn_disconnect
        ;;
    status|s)
        vpn_status
        ;;
    clean|fix)
        log_info "清理 VPN 残留路由..."
        cleanup_routes
        ;;
    *)
        echo "用法: vpn [connect|disconnect|status|clean]"
        echo "  connect (c)    - 连接 VPN"
        echo "  disconnect (d) - 断开 VPN"
        echo "  status (s)     - 查看状态"
        echo "  clean (fix)    - 清理残留路由"
        ;;
esac
